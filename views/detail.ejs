<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= menu.nama_menu %> - KantinKu</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <nav class="navbar">
        <div class="navbar-brand">KantinKu</div>
        <div class="nav-links">
            <a href="/">Beranda</a>
            <a href="/pesanan_saya">Pesanan Saya</a>
            <a href="/keranjang" class="cart-icon">
                Keranjang <span class="cart-count"><%= cart_count %></span>
            </a>
            <a href="/logout" class="btn-outline-danger btn-sm" style="margin-left: 15px; padding: 5px 15px;">Logout</a>
        </div>
    </nav>

    <div class="container" style="max-width: 900px;">
        <a href="/" style="display:inline-block; margin-bottom:20px; color:var(--primary); font-weight:600;">&larr; Kembali ke Menu</a>
        
        <div class="auth-card" style="max-width: 100%; display: flex; flex-wrap:wrap; gap: 40px; padding: 40px; text-align:left;">
            <div style="flex: 1; min-width:300px;">
                <% if(menu.gambar) { %>
                    <img src="<%= menu.gambar.startsWith('http') ? menu.gambar : '/uploads/' + menu.gambar %>" alt="<%= menu.nama_menu %>" style="width:100%; border-radius:var(--radius-md); box-shadow:var(--shadow-md);">
                <% } else { %>
                    <div style="width:100%; height:300px; background:#ddd; border-radius:var(--radius-md); display:flex; align-items:center; justify-content:center; color:#999;">No Image</div>
                <% } %>
            </div>
            <div style="flex: 1; min-width:300px; display:flex; flex-direction:column;">
                <div style="font-size:0.9rem; color:var(--secondary); text-transform:uppercase; font-weight:600; margin-bottom:10px;">
                    <%= menu.nama_kategori || 'Umum' %>
                </div>
                <h1 style="font-size:2.5rem; margin-bottom:15px; color:var(--dark);"><%= menu.nama_menu %></h1>
                <p style="color:var(--gray-600); line-height:1.6; margin-bottom:25px; flex:1;">
                    <%- menu.deskripsi.replace(/\n/g, '<br>') %>
                </p>
                <div style="font-size:2rem; font-weight:700; color:var(--primary); margin-bottom:30px;">
                    Rp <%= new Intl.NumberFormat('id-ID').format(menu.harga) %>
                </div>
                
                <form action="/detail?id=<%= menu.id %>" method="POST" style="display:flex; gap:15px; align-items:center;">
                    <input type="number" name="jumlah" value="1" min="1" class="form-control" style="width:80px; text-align:center;" required>
                    <button type="submit" name="tambah_keranjang" class="btn-primary" style="flex:1;">Tambah ke Keranjang</button>
                </form>
            </div>
        </div>
    </div>
</body>
</html>
