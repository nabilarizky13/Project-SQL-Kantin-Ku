<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard - KantinKu</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <nav class="navbar">
        <div class="navbar-brand">KantinKu <span style="font-size: 1rem; font-weight: normal; color: var(--gray-600);">Admin Panel</span></div>
        <div class="nav-links">
            <a href="/admin">Dashboard</a>
            <a href="/admin/kategori">Kategori</a>
            <a href="/admin/menu">Menu</a>
            <a href="/admin/pesanan">Pesanan</a>
            <a href="/logout" class="btn-outline-danger btn-sm" style="margin-left: 15px; padding: 5px 15px;">Logout</a>
        </div>
    </nav>
    <div class="container">

<div class="page-header">
    <h1>Dashboard</h1>
    <p>Selamat datang, <%= nama %></p>
</div>

<div class="dashboard-grid">
    <div class="stat-card">
        <div class="stat-icon">🛒</div>
        <div class="stat-value"><%= total_pesanan %></div>
        <div class="stat-label">Total Pesanan</div>
    </div>
    <div class="stat-card">
        <div class="stat-icon">⏳</div>
        <div class="stat-value"><%= pesanan_diproses %></div>
        <div class="stat-label">Pesanan Diproses</div>
    </div>
    <div class="stat-card">
        <div class="stat-icon">💰</div>
        <div class="stat-value">Rp <%= new Intl.NumberFormat('id-ID').format(total_pendapatan) %></div>
        <div class="stat-label">Total Pendapatan</div>
    </div>
    <div class="stat-card">
        <div class="stat-icon">🍔</div>
        <div class="stat-value"><%= total_menu %></div>
        <div class="stat-label">Total Menu</div>
    </div>
</div>

<div class="table-container">
    <h3 style="padding: 20px; border-bottom: 1px solid var(--gray-200);">Pesanan Terbaru</h3>
    <table>
        <thead>
            <tr>
                <th>ID Pesanan</th>
                <th>Tanggal</th>
                <th>Total Harga</th>
                <th>Status</th>
                <th>Aksi</th>
            </tr>
        </thead>
        <tbody>
            <% if (pesanan_terbaru.length > 0) {
                pesanan_terbaru.forEach(row => { %>
            <tr>
                <td>#<%= row.id %></td>
                <td><%= new Date(row.tanggal_pesan).toLocaleString('id-ID', {day: '2-digit', month: 'short', year: 'numeric', hour: '2-digit', minute:'2-digit'}) %></td>
                <td>Rp <%= new Intl.NumberFormat('id-ID').format(row.total_harga) %></td>
                <td><span class="badge badge-<%= row.status %>"><%= row.status.charAt(0).toUpperCase() + row.status.slice(1) %></span></td>
                <td><a href="/admin/pesanan" class="btn-secondary" style="font-size: 0.8rem; padding: 4px 8px;">Lihat</a></td>
            </tr>
            <% }) } else { %>
            <tr><td colspan="5" style="text-align:center;">Belum ada pesanan</td></tr>
            <% } %>
        </tbody>
    </table>
</div>

    </div>
</body>
</html>
